NODE_ENV=development
PORT=3333
LOG_LEVEL=info

# Banco: defina DATABASE_URL ou os campos DB_* (preferimos DATABASE_URL).
DATABASE_URL=postgresql://df:df@localhost:5432/df_dev?schema=public
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=df
# DB_PASS=df
# DB_NAME=df_dev

# Auth
JWT_SECRET=troque-me-por-32-ou-mais-caracteres-aleatorios
JWT_EXPIRES_IN=7d
COOKIE_SECRET=troque-me-cookie-secret-16+chars
COOKIE_SECURE=false
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173

# Régua
REGUA_CRON=0 9 * * *
REGUA_HABILITADA=true

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# Workers (executar dispatchers em processo)
WORKERS_HABILITADOS=true

# WhatsApp (Baileys)
WHATSAPP_HABILITADO=true
WHATSAPP_AUTH_DIR=./.baileys-auth
# Nome que aparece como "device" no WhatsApp Web
WHATSAPP_DEVICE_NAME=DF Distribuidora

# SMTP (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DF Distribuidora <no-reply@dfdistribuidora.com.br>"
